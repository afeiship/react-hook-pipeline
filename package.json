{
  "name": "@jswork/react-hook-pipeline",
  "version": "1.0.0",
  "description": "A React utility for dynamically composing Hook-enabled components via type-safe recursive rendering.",
  "homepage": "https://js.work",
  "type": "module",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "cd packages/example && yarn run dev",
    "preln:build": "yarn run docs",
